# ---------------------------------------------------------------------------
# RAG-FPP environment template
#
# Copy this file to `backend/.env` and fill in your own values:
#     cp backend/.env.example backend/.env
#
# The application loads this file from `backend/.env` (see langgraph.json and
# the load_dotenv() calls in backend/*). When running via docker compose, the
# service-networking values (QDRANT_HOST, EMBEDDING_SERVICE_URL, ...) are
# overridden by docker-compose.yml, so localhost defaults below are for
# running directly on the host.
# ---------------------------------------------------------------------------

# === LLM / API providers ===================================================
# The chat LLM is served through OpenRouter (OpenAI-compatible API), so you can
# point OPENROUTER_MODEL at any OpenRouter model. Model ids are vendor-prefixed
# (e.g. google/gemini-3.5-flash); a bare gemini name is auto-prefixed with google/.
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-3.5-flash
# Optional attribution headers sent to OpenRouter:
# OPENROUTER_REFERER=https://personaai.local
# OPENROUTER_APP_TITLE=PersonaAI RAG
TAVILY_API_KEY=your-tavily-api-key
LLM_TEMPERATURE=0.0
MIN_NEW_TOKENS=1024

# === Vector store (Qdrant) =================================================
# In docker compose these are overridden to QDRANT_HOST=qdrant.
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Collection name. MUST be identical for indexing (run_full_indexing.py) and
# for serving the agent — both read this same variable. Created automatically
# if it does not exist.
QDRANT_COLLECTION=personaai_rag
# QDRANT_API_KEY=                  # only for Qdrant Cloud
# QDRANT_TIMEOUT=120.0

# === Embeddings ============================================================
# Leave EMBEDDING_SERVICE_ENABLED=false to load the embedding model in-process
# (sentence-transformers on GPU). Set true to use a remote vLLM endpoint.
#
# IMPORTANT: EMBEDDING_MODEL determines the collection's vector dimension
# (Qwen/Qwen3-Embedding-8B -> 4096, any other model -> 1536). The same model
# must be used for indexing and serving; to switch models, index into a NEW,
# empty collection (dimension mismatch on an existing collection will fail).
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_BATCH_SIZE=32
EMBEDDING_SERVICE_ENABLED=false
EMBEDDING_SERVICE_URL=http://localhost:8001

# === Reranker ==============================================================
RERANKER_MODEL_PATH=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=10
RERANKER_SCORE_THRESHOLD=0.0

# === Indexing pipeline =====================================================
# Path to the source corpus used by run_full_indexing.py. The pipeline scans
# this directory recursively and indexes all .xml files.
# In docker compose this is overridden to DATA_DIR=/data.
DATA_DIR=./data

# === GPU =====================================================================
GPU_ID=0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
# Fall back to CPU if the GPU runs out of memory while loading models.
# Set to false to force GPU-only (fail fast on OOM). Default: true.
# ENABLE_CPU_FALLBACK=true

# === Agent control flow ====================================================
MAX_SEARCH_ATTEMPTS=3
MAX_WEB_SEARCH_ATTEMPTS=2
RELEVANCE_THRESHOLD=0.5
COMPLETENESS_THRESHOLD=0.7
RECURSION_LIMIT=30
